# Supabase — get from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API — get from console.anthropic.com (required for receipt OCR)
CLAUDE_API_KEY=

# Superuser emails (comma-separated) — for admin access
SUPERUSER_EMAILS=

# Azure AD — OneDrive sync (app-only, client credentials flow)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Vercel Cron — auto-provisioned by Vercel
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
